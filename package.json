{
  "name": "@wunderchat/openclaw-channel-streamchat",
  "version": "0.1.0",
  "description": "Stream Chat messaging channel plugin for OpenClaw",
  "main": "index.ts",
  "type": "module",
  "files": [
    "index.ts",
    "src",
    "openclaw.plugin.json"
  ],
  "scripts": {
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "stream-chat": "^9.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "dotenv": "^17.3.1",
    "typescript": "^5.3.0"
  },
  "peerDependencies": {
    "openclaw": ">=2026.2.13"
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "channels": [
      "streamchat"
    ],
    "installDependencies": true,
    "channel": {
      "id": "streamchat",
      "label": "Stream Chat",
      "selectionLabel": "Stream Chat",
      "docsPath": "/channels/streamchat",
      "blurb": "Stream Chat messaging channel with AI streaming support.",
      "order": 80,
      "aliases": [
        "sc"
      ]
    }
  }
}
